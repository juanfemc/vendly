APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Configure this in production when the app is behind Nginx, Cloudflare, a load balancer, or another reverse proxy.
# Example: TRUSTED_PROXIES=127.0.0.1
TRUSTED_PROXIES=

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=low
OPENAI_PROXY=

SUPPORT_WHATSAPP=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ADMIN_PHONE=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_VERSION=v24.0
WHATSAPP_TEMPLATE_LANGUAGE=es_CO
WHATSAPP_ADMIN_REGISTRATION_TEMPLATE=
WHATSAPP_CUSTOMER_WELCOME_TEMPLATE=
WHATSAPP_PHONE_VERIFICATION_TEMPLATE=
WHATSAPP_FOLLOWUP_DAY_1_TEMPLATE=seguimiento_dia_1_tienda
WHATSAPP_FOLLOWUP_DAY_3_TEMPLATE=seguimiento_dia_3_productos
WHATSAPP_FOLLOWUP_DAY_6_TEMPLATE=seguimiento_dia_6_prueba
WHATSAPP_PLAN_EXPIRES_3_DAYS_TEMPLATE=plan_vence_3_dias
WHATSAPP_PLAN_EXPIRES_1_DAY_TEMPLATE=plan_vence_manana
WHATSAPP_PLAN_EXPIRED_TEMPLATE=plan_vencido
WHATSAPP_AUTHENTICATION_BUTTON_SUB_TYPE=url
# Optional in local. Production enables phone verification by default.
# WHATSAPP_REQUIRE_PHONE_VERIFICATION=true
# Minimum successful response time reduces phone-enumeration timing differences.
WHATSAPP_VERIFICATION_MIN_RESPONSE_MS=2500
WHATSAPP_CONSENT_VERSION=registration_v1
WHATSAPP_RETENTION_DAYS=365

# Generate a stable secret for trial phone hashes before the first production migration.
# TRIAL_PHONE_HASH_KEY=

LANDING_INSTAGRAM_URL=
LANDING_FACEBOOK_URL=
LANDING_TIKTOK_URL=
LANDING_META_PIXEL_ID=

# Cloudflare Turnstile protects public WhatsApp code requests from distributed abuse.
# Production requires it by default.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# TURNSTILE_REQUIRED=true

MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
MERCADOPAGO_REDIRECT_URI="${APP_URL}/admin/payments/mercadopago/callback"
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_TEST_TOKEN=false
MERCADOPAGO_PAYMENT_EXPIRATION_MINUTES=60
MERCADOPAGO_PAYMENT_EXPIRATION_GRACE_MINUTES=30
